# Exemplo de segredos para deploy no Streamlit Community Cloud.
#
# LOCAL: continue usando o arquivo .env (python-dotenv). Este arquivo é opcional local.
# CLOUD: copie estas chaves no painel do app em Settings > Secrets (NÃO commite secrets.toml).
#
# Preencha os valores reais no painel. As chaves abaixo são lidas por lib/config.py.

# Senha de acesso ao app (gate de login). Deixe vazio para não exigir senha (uso local).
APP_PASSWORD = "troque-esta-senha"

# Supabase (use a service_role key do projeto cortex_db)
SUPABASE_URL = "https://rcjckulvccwrdpbupfws.supabase.co"
SUPABASE_SERVICE_KEY = "cole-a-service-role-key-aqui"

# Plaud
PLAUD_TOKEN = "cole-o-token-do-plaud-aqui"

# Anthropic (extração de perfil comportamental)
ANTHROPIC_API_KEY = "cole-a-api-key-da-anthropic-aqui"
ANTHROPIC_MODEL = "claude-sonnet-4-6"
